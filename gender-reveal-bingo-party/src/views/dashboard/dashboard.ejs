<%- include('../partials/header') %>
<main class="dashboard">
    <div class="page">
        <h1>Account Manager</h1>

        <p>Search for a user by their name or email</p>
        <input id="account-search" type="text">
        
        <ul id="search-results">

        </ul>

        <script>
            const accountSearch = document.getElementById('account-search');
            const resultsContainer = document.getElementById('search-results');

            async function updateSearchResults() {
                const query = accountSearch.value;

                // If the input is too short, just clear results and exit
                if (query.length < 2) {
                    resultsContainer.innerHTML = '';
                    return;
                }

                // --- START LOADING STATE ---
                // You can use an <img> tag here if you have a loading.gif
                resultsContainer.innerHTML = '<p class="loading">Searching...</p>';

                try {
                    const response = await fetch(`/api/search-users?q=${encodeURIComponent(query)}`);
                    const users = await response.json();

                    // --- END LOADING STATE (Clear the "Searching..." message) ---
                    resultsContainer.innerHTML = '';

                    if (users.length === 0) {
                        resultsContainer.innerHTML = '<p>No users found.</p>';
                        return;
                    }

                    // Insert the search results
                    for (let i = 0; i < users.length; i ++) {
                        resultsContainer.insertAdjacentHTML(
                            'beforeend',
                            `<li>
                                <p><strong>${users[i].name}</strong></p>
                                <p>Email: ${users[i].email}</p>
                                <p><small>Created At: ${users[i].createdAt}</small></p>
                                <p><small>Role: ${users[i].roleName}</small></p>
                                <a href="/dashboard/view-account/${users[i].id}" class="button">View Account</a>
                            </li>`
                        );
                    }
                } catch (error) {
                    console.error("Search Error:", error);
                    resultsContainer.innerHTML = '<p>Error loading results. Please try again.</p>';
                }
            }

            // Executes the function after the timeout has been met.
            // Prevents querying the database at every keystroke.
            function debounce(func, timeout) {
                let timer;
                return (...args) => {
                    clearTimeout(timer);
                    timer = setTimeout(() => { func.apply(this, args); }, timeout);
                };
            }

            const debouncedSearch = debounce(updateSearchResults, 300);

            accountSearch.addEventListener('input', debouncedSearch);
        </script>

    </div>
</main>
<%- include('../partials/footer') %>