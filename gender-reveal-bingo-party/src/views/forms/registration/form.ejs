<%- include('../../partials/header') %>
<main>
    
    <form method="POST" action="/register" class="registration-form">
        
        <h1>Create Account</h1>
        
        <!-- Name field -->
        <div class="form-group">
            <label for="name">Name</label>
            <input
                type="text"
                id="name"
                name="name"
                minlength="2"
                required
                placeholder="Chuck Norris"
            >
        </div>

        <!-- Email field -->
        <div class="form-group">
            <label for="email">Email</label>
            <input
                type="email"
                id="email"
                name="email"
                required
            >
        </div>

        <!-- Email confirmation field -->
        <div class="form-group">
            <label for="emailConfirm">Confirm Email</label>
            <input
                type="email"
                id="emailConfirm"
                name="emailConfirm"
                required
            >
        </div>

        <!-- Password field -->
        <div class="form-group">
            <label for="password">Password</label>
            <input
                type="password"
                id="password"
                name="password"
                minlength="8"
                pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"
                required
            >
            <div class="help-text">Must be at least 8 characters with a number and special character</div>
        </div>

        <!-- Password confirmation field -->
        <div class="form-group">
            <label for="passwordConfirm">Confirm Password</label>
            <input
                type="password"
                id="passwordConfirm"
                name="passwordConfirm"
                minlength="8"
                pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"
                required
            >
        </div>

        <!-- Submit button -->
        <button type="submit">Create Account</button>
    
        <div class="form-footer">
            <p>Already have an account? <a href="/register">Log in here</a></p>
        </div>
    
    </form>
</main>
<%- include('../../partials/footer') %>