<%- include('../partials/header') %>
<main>
    

    <form method="POST" action="/my-games/edit-game/<%= gameId %>" class="edit-game-form">
        
        <h1>Edit Game</h1>

        <!-- Title field -->
        <div class="form-group">
            <label for="title">Title</label>
            <input
                type="text"
                id="title"
                name="title"
                required
                placeholder="Jack and Jill's Gender Reveal"
                value="<%= previousTitle %>"
            >
        </div>

        <!-- Gender field -->
        <div class="form-group">
            <label for="title">Gender</label>
            <select
                id="gender"
                name="gender"
                required
            >
                <option>BOY</option>
                <option>GIRL</option>
            </select>
        </div>

        <!-- Submit button -->
        <button type="submit">Save Changes</button>

        <!-- <p>Twins!?!?  Triplets!?!?!?</p>
        <button>Add Another Baby</button> -->

    </form>
</main>
<%- include('../partials/footer') %>